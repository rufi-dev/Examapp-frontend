# ── Frontend environment (Vite) ──────────────────────────────────────
# Set these in the Vercel project (Settings → Environment Variables).
# Locally, copy to ".env". NEVER commit a real .env.

# Backend API base URL (the Hetzner backend served over HTTPS by Caddy).
# Example: https://api.bunkermath.az
VITE_BACKEND_URL=https://api.bunkermath.az

# Google OAuth client ID (must list the Vercel origin as an authorized origin)
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Cloudinary (photo upload)
VITE_CLOUD_NAME=your-cloud-name
VITE_UPLAD_PRESET=your-unsigned-upload-preset

# "production" disables React devtools; use "development" locally
VITE_DEVELOPMENT_STATUS=production
