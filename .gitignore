# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.env
node_modules
*.local

# Build output — Vercel builds from source, so the artifact shouldn't be tracked
# (tracking it makes every local build show up as U/M git noise).
dist
# Temporary build-verify output dirs
dist_*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite transient config transpile artifact
vite.config.js.timestamp-*
